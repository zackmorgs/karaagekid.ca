---
import Layout from "../layouts/Layout.astro";

const defaultGuests = 20;
const maxGuests = 50;
const bufferMultiplier = 1.15;
const baseFee = 400;

function getPricePerHead(guests: number) {
  let pricePerHead = 30;

  if (guests > 20) pricePerHead = 25;
  if (guests > 30) pricePerHead = 22;

  return pricePerHead;
}

function calculateQuote(guests: number) {
  const effectiveGuests = Math.ceil(guests * bufferMultiplier);
  const pricePerHead = getPricePerHead(guests);

  return baseFee + effectiveGuests * pricePerHead;
}

function formatCurrency(amount: number) {
  return new Intl.NumberFormat("en-CA", {
    style: "currency",
    currency: "CAD",
    maximumFractionDigits: 0,
  }).format(amount);
}

const defaultPreparedGuests = Math.ceil(defaultGuests * bufferMultiplier);
const defaultPricePerHead = getPricePerHead(defaultGuests);
const defaultQuote = calculateQuote(defaultGuests);
---

<Layout
  title="Get a Quote from Karaage Kid"
  description="Request a catering quote from Karaage Kid for pop-ups, private events, festivals, and special occasions in Toronto."
  image="/img/og/open-graph-quote.png"
>
  <header id="about" class="hero">
    <div class="overlay">
      <div class="container">
        <div class="panel">
          <h1>Get a Quote</h1>
          <p>Request a quote for your next event or catering order.</p>
        </div>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="overlay">
      <div class="container">
        <div class="panel content quote-panel">
          <p>
            Use this quick estimator to get a starting price for your catering
            order. Final quotes may vary based on menu, setup, and service
            needs.
          </p>

          <div class="quote-calculator">
            <div class="input-group">
              <label for="guests">Number of Guests</label>
              <input
                type="number"
                placeholder="Number of Guests"
                id="guests"
                class="input"
                min="1"
                max={maxGuests}
                step="1"
                value={defaultGuests}
              />
              <input
                type="range"
                id="guestsRange"
                class="quote-range"
                min="20"
                max={maxGuests}
                step="1"
                value={defaultGuests}
              />
              <br>
              <p id="quote-help" class="quote-help">
                Online estimates are available for up to 50 guests. For larger
                events, email us for a custom quote.
              </p>
            </div>
            
            <div class="quote-estimate" aria-live="polite">
              <p class="quote-kicker">Estimated catering total</p>
              <p id="quoteTotal" class="quote-total">
                {formatCurrency(defaultQuote)}
              </p>

              <div class="quote-meta">
                <div>
                  <span>Rate</span>
                  <strong id="pricePerHead">
                    {formatCurrency(defaultPricePerHead)}/guest
                  </strong>
                </div>
                <div>
                  <span>Food prepared for</span>
                  <strong id="effectiveGuests"
                    >{defaultPreparedGuests} servings</strong
                  >
                </div>
                <div>
                  <span>Large groups</span>
                  <strong id="serviceFee">Custom quote for 51+ guests</strong>
                </div>
              </div>
            </div>
          </div>
          <br>
          <div class="quote-breakdown">
            <h2>Pricing Tiers</h2>
            <ul class="quote-tiers">
              <li><span>1–20 guests</span><strong>$30/head</strong></li>
              <li><span>21–30 guests</span><strong>$25/head</strong></li>
              <li><span>31–50 guests</span><strong>$22/head</strong></li>
              <li><span>51+ guests</span><strong>Custom quote</strong></li>
            </ul>
          </div>
          <br />
          <p class="quote-disclaimer">
            Need a final quote? Email us and we’ll help tailor the menu for your
            event.
          </p>
          <br />
          <div class="btn-group-horizontal quote-actions">
            <a
              href="mailto:contact.karaagekid@gmail.com?subject=Catering%20Quote%20Request"
              class="btn btn-cta">Get a Formal Quote</a
            >
            <a href="/contact" class="btn btn-cta">Contact</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>


<script>
  const initQuoteCalculator = () => {
    const guestInput = document.querySelector("#guests");
    const guestRange = document.querySelector("#guestsRange");
    const totalOutput = document.querySelector("#quoteTotal");
    const effectiveGuestsOutput = document.querySelector("#effectiveGuests");
    const pricePerHeadOutput = document.querySelector("#pricePerHead");
    const serviceFeeOutput = document.querySelector("#serviceFee");

    if (
      !(guestInput instanceof HTMLInputElement) ||
      !(guestRange instanceof HTMLInputElement) ||
      !(totalOutput instanceof HTMLElement) ||
      !(effectiveGuestsOutput instanceof HTMLElement) ||
      !(pricePerHeadOutput instanceof HTMLElement) ||
      !(serviceFeeOutput instanceof HTMLElement) ||
      guestInput.dataset.bound === "true"
    ) {
      return;
    }

    guestInput.dataset.bound = "true";

    const maxGuests = Number(
      guestInput.getAttribute("max") ?? guestRange.getAttribute("max") ?? 50,
    );

    /** @param {number} amount */
    const formatCurrency = (amount : number ) =>
      new Intl.NumberFormat("en-CA", {
        style: "currency",
        currency: "CAD",
        maximumFractionDigits: 0,
      }).format(amount);

    /** @param {number} guests */
    const getPricePerHead = (guests : number ) => {
      let pricePerHead = 30;

      if (guests > 20) pricePerHead = 25;
      if (guests > 30) pricePerHead = 22;

      return pricePerHead;
    };

    /** @param {number} guests */
    const calculateQuote = (guests : number ) => {
      const effectiveGuests = Math.ceil(guests * 1.15);
      const pricePerHead = getPricePerHead(guests);
      const total = 400 + effectiveGuests * pricePerHead;

      return {
        total,
        effectiveGuests,
        pricePerHead,
        serviceFee: 0,
      };
    };

    /** @param {string | number} value */
    const updateQuote = (value : number ) => {
      const parsedGuests = Number.parseInt(String(value), 10) || 1;
      const guests = Math.min(maxGuests, Math.max(1, parsedGuests));
      const quote = calculateQuote(guests);

      guestInput.value = String(guests);
      guestRange.value = String(guests);
      totalOutput.textContent = formatCurrency(quote.total);
      effectiveGuestsOutput.textContent = `${quote.effectiveGuests} servings`;
      pricePerHeadOutput.textContent = `${formatCurrency(quote.pricePerHead)}/guest`;
      serviceFeeOutput.textContent = "Custom quote for 51+ guests";
    };

    guestInput.addEventListener("input", () => {
      updateQuote(Number(guestInput.value));
    });

    guestRange.addEventListener("input", () => {
      updateQuote(Number(guestRange.value));
    });

    updateQuote(Number(guestInput.value) || 20);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initQuoteCalculator, {
      once: true,
    });
  } else {
    initQuoteCalculator();
  }

  document.addEventListener("astro:page-load", initQuoteCalculator);
</script>
