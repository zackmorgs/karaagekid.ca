  {
    src: "/img/gallery/1.png",
    alt: "",
  },
  {
    src: "/img/gallery/2.png",
    alt: "",
  },
  {
    src: "/img/gallery/3.png",
    alt: "",
  },
  {
    src: "/img/gallery/4.png",
    alt: "",
  },
  {
    src: "/img/gallery/5.png",
    alt: "",
  },
  {
    src: "/img/gallery/6.png",
    alt: "",
  },
  {
    src: "/img/gallery/7.png",
    alt: "",
  },
  {
    src: "/img/gallery/8.png",
    alt: "",
  },
  {
    src: "/img/gallery/9.png",
    alt: "",
  },
  {
    src: "/img/gallery/10.png",
    alt: "",
  },
    {
    src: "/img/gallery/15.jpg",
    alt: "",
  },
    {
    src: "/img/gallery/16.jpg",
    alt: "",
  },
    {
    src: "/img/gallery/17.jpg",
    alt: "",
  },
    {
    src: "/img/gallery/18.jpg",
    alt: "",
  },
    {
    src: "/img/gallery/19.jpg",
    alt: "",
  },
    {
    src: "/img/gallery/20.jpg",
    alt: "",
  }
];
---

<section class="gallery" data-gallery-root>
  <div class="overlay">
    <div class="container">
      <div class="panel">
        <div class="gallery-grid">
          {
            images.map((image, index) => {
              const altText =
                image.alt || `Karaage Kid gallery photo ${index + 1}`;

              return (
                <button
                  type="button"
                  class="gallery-trigger"
                  data-gallery-image
                  data-fullsrc={image.src}
                  data-alt={altText}
                  aria-label={`Open ${altText} fullscreen`}
                >
                  <img
                    src={image.src}
                    alt={altText}
                    class="gallery-img"
                    loading="lazy"
                  />
                </button>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>

  <dialog class="gallery-modal" aria-label="Fullscreen gallery image">
    <div class="gallery-modal-shell">
      <button
        type="button"
        class="gallery-modal-close"
        data-gallery-close
        aria-label="Close fullscreen image"
      >
        ×
      </button>

      <img class="gallery-modal-image" src="" alt="" />
    </div>
  </dialog>
</section>

<script>
  document
    .querySelectorAll<HTMLElement>("[data-gallery-root]")
    .forEach((gallery) => {
      if (gallery.dataset.modalBound === "true") {
        return;
      }

      gallery.dataset.modalBound = "true";

      const modal = gallery.querySelector(".gallery-modal");
      const modalImage = gallery.querySelector(".gallery-modal-image");
      const closeButton = gallery.querySelector<HTMLButtonElement>(
        "[data-gallery-close]",
      );
      const imageButtons = gallery.querySelectorAll<HTMLElement>(
        "[data-gallery-image]",
      );

      if (
        !(modal instanceof HTMLDialogElement) ||
        !(modalImage instanceof HTMLImageElement)
      ) {
        return;
      }

      const openModal = (src: string, alt: string) => {
        modalImage.src = src;
        modalImage.alt = alt;
        document.body.style.overflow = "hidden";
        modal.showModal();
      };

      const closeModal = () => {
        modal.close();
      };

      imageButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const src = button.getAttribute("data-fullsrc");
          const alt = button.getAttribute("data-alt") || "Gallery image";

          if (!src) {
            return;
          }

          openModal(src, alt);
        });
      });

      closeButton?.addEventListener("click", closeModal);

      modal.addEventListener("click", (event) => {
        if (event.target === modal) {
          closeModal();
        }
      });

      modal.addEventListener("close", () => {
        document.body.style.overflow = "";
        modalImage.src = "";
        modalImage.alt = "";
      });
    });
</script>
