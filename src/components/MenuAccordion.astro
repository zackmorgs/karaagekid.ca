---
import menuSections from "../data/menuSections.json";
---

<section id="menu_accordion">
  <div class="overlay">
    <div class="container">
      <div class="panel">
        <h2>Menu</h2>
        <div class="accordion">
          {
            menuSections.map((section) => (
              <details class="accordion-item">
                <summary class="accordion-summary">
                  <span>{section.title}</span>
                  <svg class="accordion-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9" />
                  </svg>
                </summary>
                <div class="accordion-body">
                  {section.note && (
                    <p class="accordion-note">{section.note}</p>
                  )}
                  <ul class="accordion-list">
                    {section.items.map((item) => (
                      <li class="accordion-menu-item">
                        <span class="item-name">{item.name}</span>
                        <span class="item-desc">{item.description}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .accordion {
    width: 100%;
    max-width: 36rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .accordion-item {
    /* background: rgb(39 39 39); */
    border: 2px solid rgba(241, 241, 241, 0.212);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .accordion-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 1rem;
    cursor: pointer;
    list-style: none;
    /* font-family: "Porter-Bold", sans-serif; */
    font-size: 1rem;
    color: rgb(160 157 157);
    user-select: none;
  }

  .accordion-summary::-webkit-details-marker {
    display: none;
  }

  .accordion-icon {
    flex-shrink: 0;
    transition: transform 0.2s ease;
    color: #c7c6c8;
  }

  details[open] .accordion-icon {
    transform: rotate(180deg);
  }

  .accordion-body {
    padding: 0 1rem 1rem;
    border-top: 1px solid rgba(255 255 255 / 0.08);
  }

  .accordion-note {
    font-size: 0.8rem;
    color: #a09fa1;
    margin: 0.75rem 0 0.75rem;
    line-height: 1.5;
  }

  .accordion-list {
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .accordion-menu-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .item-name {
    font-family: "Porter-Medium", sans-serif;
    font-size: 0.95rem;
    color: #f1f1f1;
  }

  .item-desc {
    font-size: 0.8rem;
    color: #a09fa1;
    line-height: 1.5;
  }
</style>