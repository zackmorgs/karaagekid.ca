---
import menuSections from "../data/menuSections.json";
---

<header class="hero">
  <div class="overlay">
    <div class="container">
      <div class="panel">
        <h1>Menu</h1>
        <p>Explore our delicious offerings</p>
      </div>
    </div>
  </div>
</header>

<section id="menu">
  <div class="overlay">
    <div class="container">
      <div class="panel menu-panel">
        <p class="menu-intro">
          Japanese-inspired comfort food built around our signature karaage. <b>All sauces made in-house.</b></p>
        <div class="menu-grid">
          {
            menuSections.map((section) => (
              <div class="menu-section">
                <h2>{section.title}</h2>
                {section.note && (
                  <p class="menu-section-note">{section.note}</p>
                )}

                <ul class="menu-list">
                  {section.items.map((item) => (
                    <li class="menu-item">
                      <h3>{item.name}</h3>
                      <p>{item.description}</p>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
