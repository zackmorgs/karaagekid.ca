---
const menuSections = [
  {
    title: "Karaage Plates",
    items: [
      {
        name: "3-Piece Karaage",
        description:
          "Crispy Japanese-style fried chicken served over a bed of purple rice.",
      },
    ],
  },
  {
    title: "Karaage Boxes",
    items: [
      {
        name: "Japanese Curry Box",
        description:
          "Rich Japanese curry served with assorted fried vegetables and karaage.",
      },
      {
        name: "Spicy Sesame Box",
        description: "Karaage with sesame sauce and spicy mayo.",
      },
      {
        name: "Citrus Garlic Box",
        description: "Karaage with citrus soy glaze and garlic mayo.",
      },
    ],
  },
  {
    title: "Karaage Sandwiches",
    note: "Served on a brioche bun with coleslaw, daikon, or pickles.",
    items: [
      {
        name: "Karaage Sandwich (Mild)",
        description:
          "Topped with sesame sauce, spicy mayo, and crispy onions.",
      },
      {
        name: "Nashville Hot Sandwich",
        description:
          "Spicy karaage topped with buttermilk ranch and crispy onions.",
      },
    ],
  },
  {
    title: "Snacks",
    items: [
      {
        name: "Panko Fried Hot Dog Skewers",
        description: "Served with sesame sauce and spicy mayo.",
      },
      {
        name: "Takoyaki",
        description: "Japanese octopus balls served with your choice of sauce.",
      },
    ],
  },
];
---

<header class="hero">
  <div class="container">
    <div class="overlay">
      <div class="panel">
        <h1>Menu</h1>
      </div>
    </div>
  </div>
</header>

<section id="menu">
  <div class="container">
    <div class="panel menu-panel">
      <p class="menu-intro">
        Japanese-inspired comfort food built around our signature karaage.
      </p>

      <div class="menu-grid">
        {menuSections.map((section) => (
          <div class="menu-section">
            <h2>{section.title}</h2>
            {section.note && <p class="menu-section-note">{section.note}</p>}

            <ul class="menu-list">
              {section.items.map((item) => (
                <li class="menu-item">
                  <h3>{item.name}</h3>
                  <p>{item.description}</p>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

